[general]
targets = gitlab_com

[gitlab_com]
service = gitlab
gitlab.host = gitlab.com
gitlab.login = cgreen-i2
# Restrict to projects I'm a member of (required on gitlab.com — too many repos to
# fetch all). only_if_assigned below then narrows issues/MRs to those assigned to me.
gitlab.membership = true
gitlab.owned = false
# Reuse the GITLAB_TOKEN exported from fish/conf.d/private.fish (gitignored) so no
# secret is hard-coded here and this file is safe to commit.
gitlab.token = @oracle:eval:echo $GITLAB_TOKEN
gitlab.include_merge_requests = true
gitlab.include_todos = true
# Only pull issues/MRs assigned to me (todos are inherently mine).
gitlab.only_if_assigned = cgreen-i2

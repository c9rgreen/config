[user]
    # Git identity for commits
    name = Christopher Green
    # Prevent commits using a guessed email; must be set explicitly per-repo or globally
    useConfigOnly = true
[alias]
    # Fancier git log
    graph = !git log --graph --oneline --abbrev-commit --decorate  --all

    # Jump
    jump = !$(brew --prefix git)/share/git-core/contrib/git-jump/git-jump

    # Print the commit SHA of the last common ancestor.
    # $REVIEW_BASE should usually be set to "main".
    last = !git merge-base HEAD "$REVIEW_BASE"

    # List an overview of changed files
    changed = !git diff --stat $(git last)

    # Populate quickfix list with every changed file
    review = !git jump diff $(git last)

    # Shortcuts
    s = status
    a = add
    c = commit
    d = diff
    dt = difftool
    dd = difftool --dir-diff
[github]
    # GitHub username used by the gh CLI
    user = c9rgreen
[pull]
    # Refuse to pull if the result would require a merge commit; rebase manually instead
    ff = only
[fetch]
    # Remove remote-tracking branches that no longer exist on the remote
    prune = true

    # Remove local tags which have been deleted on the remote
    pruneTags = true

    # Fetch all remotes by default
    all = true
[init]
    # Default branch name for new repositories
    defaultBranch = main
[push]
    # Automatically set the upstream when pushing a new local branch
    autoSetupRemote = true

    # Push annotated tags alongside commits (lightweight tags are excluded)
    followTags = true

[difftool "nvim_difftool"]
    # https://neovim.io/doc/user/plugins/#_builtin-plugin:-difftool
    cmd = nvim -c \"packadd nvim.difftool\" -d \"$LOCAL\" \"$REMOTE\"

[diff]
    # Use Neovim as the difftool
    tool = nvim_difftool

    # Histogram produces cleaner diffs than the default Myers algorithm
    algorithm = histogram

    # Highlight lines that were moved rather than changed
    colorMoved = plain

    # Use i/ (index) and w/ (worktree) prefixes instead of a/ and b/
    mnemonicPrefix = true

    # Detect file renames
    renames = true
[merge]
    # Use Neovim as the mergetool
    tool = nvimdiff
[rebase]
    # Automatically squash fixup! and squash! commits onto their targets
    autoSquash = true

    # Stash uncommitted changes before rebasing and reapply them after
    autoStash = true

    # Also rebase any branches that depend on the rebased branch
    updateRefs = true
[column]
    # Show columnar output only when writing to a terminal
    ui = auto
[branch]
    # Sort branches by most recently committed
    sort = -committerdate
[help]
    # Prompt for confirmation before applying an autocorrected command
    autocorrect = prompt
[commit]
    # Show a diff of staged changes when composing a commit message
    verbose = true
[rerere]
    # Remember how merge conflicts were resolved and reuse those resolutions
    enabled = true

    # Automatically stage rerere-resolved files
    autoupdate = true
